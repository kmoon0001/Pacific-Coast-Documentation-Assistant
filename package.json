{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port=3001 --host=0.0.0.0",
    "build": "vite build",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\"",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest --run",
    "test:coverage": "vitest --run --coverage",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:debug": "playwright test --debug",
    "type-check": "tsc --noEmit",
    "test:uat": "playwright test --grep @uat",
    "test:visual": "playwright test --grep @visual",
    "test:smoke": "playwright test e2e/smoke.spec.ts",
    "test:spike": "tsx load-tests/spikeTest.ts",
    "test:load": "tsx load-tests/backendLoad.ts",
    "test:resilience": "tsx load-tests/resilienceCheck.ts",
    "electron:start": "wait-on tcp:3001 && cross-env NODE_ENV=development VITE_DEV_SERVER_URL=http://127.0.0.1:3001 electron .",
    "electron:dev": "concurrently \"npm run dev\" \"npm run electron:start\"",
    "electron:build": "npm run build && electron-builder"
  },
  "dependencies": {},
  "devDependencies": {
    "@playwright/test": "^1.48.2",
    "@sentry/react": "^8.34.0",
    "@tailwindcss/vite": "^4.1.14",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/dompurify": "^3.0.5",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@types/supertest": "^7.2.0",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "@vitejs/plugin-react": "^5.0.4",
    "@vitest/coverage-v8": "^4.1.2",
    "@vitest/ui": "^4.1.2",
    "@xenova/transformers": "^2.17.2",
    "autoprefixer": "^10.4.21",
    "axe-core": "^4.10.0",
    "axe-playwright": "^1.2.3",
    "clsx": "^2.1.1",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "dompurify": "^3.3.3",
    "dotenv": "^17.2.3",
    "electron": "^41.1.1",
    "electron-builder": "^26.8.1",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react": "^7.37.2",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^15.14.0",
    "husky": "^9.1.7",
    "jsdom": "^29.0.1",
    "lint-staged": "^15.2.11",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "msw": "^2.6.0",
    "pino": "^9.5.0",
    "pino-pretty": "^11.2.2",
    "prettier": "^3.4.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "supertest": "^7.2.2",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^6.2.0",
    "vitest": "^4.1.2",
    "vitest-axe": "^0.1.0",
    "wait-on": "^8.0.1",
    "zod": "^3.23.8"
  },
  "main": "electron/main.cjs",
  "build": {
    "appId": "com.pacificcoast.docassistant",
    "productName": "Pacific Coast Documentation Assistant",
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "directories": {
      "buildResources": "build"
    },
    "asar": true,
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    }
  }
}
