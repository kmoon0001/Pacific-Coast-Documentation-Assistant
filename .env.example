# AWS Bedrock Configuration (Required for AI features)
# Get credentials from AWS IAM - create user with Bedrock permissions
AWS_ACCESS_KEY_ID="your-aws-access-key-id"
AWS_SECRET_ACCESS_KEY="your-aws-secret-access-key"
AWS_REGION="us-east-1"

# Model selection (optional - defaults to Claude 3 Sonnet)
# Available models:
# - anthropic.claude-3-sonnet-20240229-v1:0 (recommended for clinical notes)
# - anthropic.claude-3-haiku-20240307-v1:0 (faster, lower cost)
# - meta.llama3-70b-instruct-v1:0
# - mistral.mistral-large-2407-v1:0
AWS_MODEL_ID="anthropic.claude-3-sonnet-20240229-v1:0"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
